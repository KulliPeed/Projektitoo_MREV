# Copy this file to .env on the live server and fill in real values there.
# Do not commit .env. This file contains placeholders only.

# PostgreSQL connection for Python loaders and data quality runner.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=andmeprojekt
DB_USER=andrus
DB_PASSWORD=CHANGE_ME
# Alternative accepted by loaders/runner:
# POSTGRES_PASSWORD=CHANGE_ME

# Optional data quality runner flags used by paevane_pipeline_refresh.sh
# when .env exists in PROJECT_DIR.
RUN_DATA_QUALITY_CHECKS=false
DATA_QUALITY_FAIL_PIPELINE=false
DATA_QUALITY_BAD_ROWS_LIMIT=1000

# Optional data quality metadata.
DATA_QUALITY_TRIGGERED_BY=cron
# PROJECT_DIR=/home/pi/kool/projekt
