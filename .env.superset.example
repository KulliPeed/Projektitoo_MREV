# Superset application secret. Generate with:
# openssl rand -base64 42
SUPERSET_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET

# Superset metadata database.
SUPERSET_META_DB_NAME=superset_meta
SUPERSET_META_DB_USER=superset_meta
SUPERSET_META_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SUPERSET_METADATA_DB_URI=postgresql+psycopg2://superset_meta:CHANGE_ME_STRONG_PASSWORD@andmeprojekt_postgres:5432/superset_meta

# Read-only connection from Superset to analytical mart views.
SUPERSET_READONLY_DB_USER=superset_readonly
SUPERSET_READONLY_DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Initial Superset admin account.
SUPERSET_ADMIN_USERNAME=andrus_admin
SUPERSET_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
SUPERSET_ADMIN_FIRSTNAME=Andrus
SUPERSET_ADMIN_LASTNAME=Admin
SUPERSET_ADMIN_EMAIL=andrus@example.com

# Optional team users. Do not commit real values.
SUPERSET_TUULI_USERNAME=tuuli
SUPERSET_TUULI_EMAIL=
SUPERSET_TUULI_PASSWORD=
SUPERSET_KULLI_USERNAME=kulli
SUPERSET_KULLI_EMAIL=
SUPERSET_KULLI_PASSWORD=
